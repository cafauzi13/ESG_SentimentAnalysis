      "source": [
        "import pandas as pd\n",
        "from google.colab import files\n",
        "import io\n",
        "\n",
        "# 1. Upload file (Pilih file raw_multatuli.csv dan link_multatuli.csv)\n",
        "print(\"Silakan upload kedua file (raw_multatuli.csv dan link_multatuli.csv):\")\n",
        "uploaded = files.upload()\n",
        "\n",
        "# 2. Baca file yang sudah di-upload\n",
        "# Pastikan nama file di komputer kamu sama dengan yang ditulis di bawah ini\n",
        "df_raw = pd.read_csv(io.BytesIO(uploaded['raw_multatuli.csv']))\n",
        "df_ref = pd.read_csv(io.BytesIO(uploaded['link_multatuli.csv']))\n",
        "\n",
        "# 3. Hapus kolom 'No' di kedua dataframe (sesuai instruksi)\n",
        "if 'No' in df_raw.columns:\n",
        "    df_raw = df_raw.drop(columns=['No'])\n",
        "if 'No' in df_ref.columns:\n",
        "    df_ref = df_ref.drop(columns=['No'])\n",
        "\n",
        "# 4. Bersihkan df_raw dari kolom 'Sentiment' dan 'Tag' yang masih kosong\n",
        "# Supaya tidak ada kolom duplikat saat di-merge\n",
        "df_raw_clean = df_raw.drop(columns=['Sentiment', 'Tag'], errors='ignore')\n",
        "\n",
        "# 5. Proses Mencocokkan data berdasarkan 'Link'\n",
        "# Kita ambil Link, Sentiment, dan Tag dari data referensi\n",
        "df_final = pd.merge(\n",
        "    df_raw_clean,\n",
        "    df_ref[['Link', 'Sentiment', 'Tag']],\n",
        "    on='Link',\n",
        "    how='left'\n",
        ")\n",
        "\n",
        "# 6. Hapus duplikat baris (karena data contohmu punya banyak link yang sama)\n",
        "df_final = df_final.drop_duplicates().reset_index(drop=True)\n",
        "\n",
        "# 7. Simpan dan Download hasilnya\n",
        "nama_file_hasil = 'hasil_multatuli_final.csv'\n",
        "df_final.to_csv(nama_file_hasil, index=False)\n",
        "files.download(nama_file_hasil)\n",
        "\n",
        "print(\"\\n--- Selesai! ---\")\n",
        "print(f\"Data berhasil digabung. Total baris: {len(df_final)}\")\n",
        "df_final.head()"
      ]
    }
  ]
}